generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model RagDocument {
  id            Int               @id @default(autoincrement())
  filename      String
  originalName  String            @map("original_name")
  pageCount     Int?              @map("page_count")
  chunkCount    Int               @default(0) @map("chunk_count")
  status        String            @default("processing")
  createdAt     DateTime          @default(now()) @map("created_at")
  userId        Int?              @map("user_id")
  chunks        RagChunk[]
  conversations RagConversation[]
  user          User?             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("rag_documents")
}

model RagChunk {
  id           Int         @id @default(autoincrement())
  documentId   Int         @map("document_id")
  chunkIndex   Int         @map("chunk_index")
  content      String
  pageNumber   Int?        @map("page_number")
  searchVector String?     @map("search_vector")
  document     RagDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("rag_chunks")
}

model RagConversation {
  id         Int         @id @default(autoincrement())
  documentId Int         @map("document_id")
  role       String
  content    String
  sources    String?
  createdAt  DateTime    @default(now()) @map("created_at")
  document   RagDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("rag_conversations")
}

model CodeReview {
  id                Int      @id @default(autoincrement())
  language          String
  code              String
  summary           String?
  findings          String?
  overallSeverity   String?  @map("overall_severity")
  bugCount          Int      @default(0) @map("bug_count")
  securityCount     Int      @default(0) @map("security_count")
  perfCount         Int      @default(0) @map("perf_count")
  qualityCount      Int      @default(0) @map("quality_count")
  bestPracticeCount Int      @default(0) @map("best_practice_count")
  status            String   @default("pending")
  createdAt         DateTime @default(now()) @map("created_at")

  @@map("code_reviews")
}

model User {
  id        Int           @id @default(autoincrement())
  email     String        @unique
  password  String        @map("password_hash")
  name      String?
  createdAt DateTime      @default(now()) @map("created_at")
  documents RagDocument[]

  @@map("users")
}
